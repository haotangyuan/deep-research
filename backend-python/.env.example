# Database
DB_URL=jdbc:mysql://127.0.0.1:3306/db_deep_research?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USERNAME=root
DB_PASSWORD=12345678

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Tavily
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_CACHE_ENABLED=true
TAVILY_CACHE_TTL_MINUTES=60
TAVILY_CACHE_MAX_ENTRIES=512

# Search processing
RESEARCH_SEARCH_MAX_RESULTS_PER_QUERY=3
RESEARCH_SEARCH_SUMMARY_TIMEOUT_SECONDS=60
RESEARCH_SEARCH_SUMMARY_RAW_CONTENT_MAX_CHARS=12000
RESEARCH_SEARCH_SUMMARY_FALLBACK_CONTENT_MAX_CHARS=1200
RESEARCH_SEARCH_SUMMARY_CACHE_ENABLED=true
RESEARCH_SEARCH_SUMMARY_CACHE_TTL_MINUTES=60
RESEARCH_SEARCH_SUMMARY_CACHE_MAX_ENTRIES=1024
RESEARCH_REPORT_FINDINGS_MAX_CHARS=20000

# JWT
JWT_SECRET=deep-research-jwt-secret-key-must-be-at-least-32-chars
JWT_EXPIRATION=10080

# Runtime
APP_TIME_ZONE=Asia/Shanghai
RESEARCH_AGENT_FRAMEWORK=agentscope-python
LLM_TIMEOUT=300

# Async queue
RESEARCH_ASYNC_MAX_POOL_SIZE=10
RESEARCH_ASYNC_QUEUE_CAPACITY=50
RESEARCH_ASYNC_TASK_TIMEOUT_MINUTES=3

# Observability
RESEARCH_OBSERVABILITY_ENABLED=false
RESEARCH_OBSERVABILITY_PROVIDER=none
RESEARCH_OBSERVABILITY_ENDPOINT=
RESEARCH_OBSERVABILITY_CAPTURE_IO=false
RESEARCH_OBSERVABILITY_IO_MAX_CHARS=500
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_INGESTION_VERSION=4
